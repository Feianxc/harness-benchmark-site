{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "paths": {
      "@ohbp/validator-core": [
        "packages/validator-core/dist/index.d.ts"
      ],
      "@ohbp/validator-rules": [
        "packages/validator-rules/dist/index.d.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "src/**/*.test.ts"
  ]
}
