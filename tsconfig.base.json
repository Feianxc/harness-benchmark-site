{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@ohbp/schema": [
        "packages/schema/src/index.ts"
      ],
      "@ohbp/canonical": [
        "packages/canonical/src/index.ts"
      ],
      "@ohbp/types": [
        "packages/types/src/index.ts"
      ],
      "@ohbp/validator-core": [
        "packages/validator-core/src/index.ts"
      ],
      "@ohbp/validator-rules": [
        "packages/validator-rules/src/index.ts"
      ],
      "@ohbp/verifier-core": [
        "packages/verifier-core/src/index.ts"
      ],
      "@ohbp/fixtures": [
        "packages/fixtures/src/index.ts"
      ],
      "@ohbp/view-models": [
        "packages/view-models/src/index.ts"
      ]
    }
  }
}
